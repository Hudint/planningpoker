# Server hostname (defaults to "localhost")
HOSTNAME=localhost

# Port the server listens on (defaults to 3000)
PORT=3000

# Set to "production" for production deployments
NODE_ENV=development

# Secret used to sign and verify JWT tokens.
# Must be changed to a strong random value in production.
JWT_SECRET=dev-secret-please-change-in-production

# Set to "true" to add a <meta name="robots" content="noindex, nofollow"> tag
# to all pages, preventing search engines from indexing the site.
NOINDEX=false
